---
const navItems = [
  { href: '/how-it-works', label: 'How it works' },
  { href: '/primary', label: '1 · Primary' },
  { href: '/secondary', label: '2 · Secondary' },
  { href: '/university', label: '3 · University' },
  { href: '/industry', label: '4 · Industry' },
  { href: '/about', label: 'About' },
];

const currentPath = new URL(Astro.request.url).pathname;
---

<header class="border-b border-navy-100 bg-white/90 backdrop-blur sticky top-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2">
      <span class="flex h-9 w-9 items-center justify-center rounded-md bg-navy-900 text-sm font-bold text-orange-400">AI</span>
      <span class="text-lg font-bold text-navy-950">Palestra<span class="text-orange-500">.</span>AI</span>
      <span class="hidden text-xs font-medium uppercase tracking-widest text-navy-400 md:inline">Platform</span>
    </a>
    <nav class="hidden gap-6 text-sm font-medium text-navy-700 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'transition hover:text-orange-600',
            currentPath.startsWith(item.href) && 'text-orange-600',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a href="/about" class="btn-secondary hidden md:inline-flex">Demo brief</a>
  </div>
  <nav class="flex gap-4 overflow-x-auto border-t border-navy-100 px-6 py-2 text-xs font-medium text-navy-700 md:hidden">
    {navItems.map((item) => (
      <a href={item.href} class="whitespace-nowrap transition hover:text-orange-600">{item.label}</a>
    ))}
  </nav>
</header>
