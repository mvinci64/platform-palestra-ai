---
interface Props {
  status: 'live' | 'mockup' | 'roadmap';
  label: string;
}
const { status, label } = Astro.props;

const styles: Record<Props['status'], string> = {
  live: 'bg-orange-100 text-orange-700 border-orange-200',
  mockup: 'bg-navy-100 text-navy-700 border-navy-200',
  roadmap: 'bg-navy-50 text-navy-500 border-navy-100',
};
---

<span class={`inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold ${styles[status]}`}>
  {label}
</span>
