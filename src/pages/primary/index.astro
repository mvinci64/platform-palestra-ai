---
import Layout from '../../layouts/Layout.astro';
import StatusBadge from '../../components/StatusBadge.astro';

const stations = [
  {
    n: 1,
    name: 'Talento',
    subtitle: 'Talent & Self-Discovery',
    objective: 'Establish that talent is plural, that each pupil has their own, and that discovering personal talent precedes any technical literacy — countering the default school framing of talent as monolithic and competitive.',
    materials: 'Cartelloni illustrati, post-it of multiple colours, pencils, the "Talento" station board. Pupils write/draw one talent per post-it — later re-aggregated in the immersive room.',
    outline: [
      'Co-educator opens with a personal story of their own talent discovery.',
      'Pupils write 2–3 talents on post-its.',
      'Round-robin sharing — the co-educator anchors that talents are different and complementary, not ranked.',
      'Closing reflection: "What is something only you can do?"',
    ],
    outcomes: 'Pupils articulate at least one talent in their own words, recognise classmates have different talents, and reduce the implicit ranking frame typical of school assessment.',
    rating: '71%',
    ratingLabel: 'positive station rating',
    recall: '52% of pupils named "Ognuno ha talenti diversi" (everyone has different talents) as the lesson they remembered.',
  },
  {
    n: 2,
    name: 'Valore',
    subtitle: 'From Talent to Contribution',
    objective: 'Move from individual identification of talent (Station 1) to the social and ethical question of contribution: my talent has value when it helps someone else.',
    materials: 'Cartelloni illustrati, post-it, the "Valore" station board, the discussion game "Il gioco della Stazione Valore".',
    outline: [
      'Co-educator presents three scenarios in which a talent is used — well, badly, neutrally.',
      'Pupils discuss and place post-its with examples of their own talent used to help others.',
      'Closing reflection: "Whose day could you make better with your talent?"',
    ],
    outcomes: 'Pupils connect their identified talent to a contribution; vocabulary expands from ability-focused to value-focused — bridging into the ethical dimension of Station 4.',
    rating: '72%',
    ratingLabel: 'positive station rating',
    recall: '51% of pupils named "Il mio talento può aiutare gli altri" (my talent can help others) as the lesson they remembered.',
  },
  {
    n: 3,
    name: 'Successo',
    subtitle: 'Redefining Success',
    objective: 'Surface and gently challenge the default school definition of success (top grade, winning, ranking) and introduce a more research-grounded definition that includes process, growth and meaning.',
    materials: 'Cartelloni illustrati, post-it, the "Successo" station board, the discussion game "Il gioco della Stazione Successo".',
    outline: [
      'Co-educator presents two stories — one of effort without external recognition, one with recognition.',
      'Pupils vote post-its on which is the "real" success and discuss.',
      'Co-educator anchors that success has multiple dimensions, of which winning is only one.',
    ],
    outcomes: 'Pupils articulate at least two non-victory dimensions of success (effort, learning, helping others) and resist the binary win/lose framing in later conversations.',
    rating: '78%',
    ratingLabel: 'positive rating — the most liked of the three concept stations',
    recall: '61% of pupils named "Il successo non è solo vincere" (success is not only about winning) — the single largest concept-recall figure of the entire POST evaluation.',
    featured: true,
  },
  {
    n: 4,
    name: 'Comic-Strip Review',
    subtitle: 'Human-in-the-Loop',
    objective: "Introduce — concretely, through inspection of real generative outputs — that AI models hallucinate, miss details, get details wrong, and propose stereotyped visuals. The pupil is the corrector, not the consumer.",
    materials: 'Generated comic strips from the 4E pipeline, printed and shown side by side with the source story. Markers and post-its to flag errors against categories: missing detail, wrong detail, stereotype, inconsistency.',
    outline: [
      'Co-educator shows a pair: story + AI-generated comic.',
      'Pupils inspect the comic and flag what is wrong, missing or inconsistent.',
      'Discussion of why these errors occur and what it means for trusting AI outputs without checking.',
      'Closing reflection: "When would you check what an AI tells you?"',
    ],
    outcomes: 'Pupils develop a habit of inspection rather than acceptance of AI outputs, articulate at least one failure mode of generative models, and transfer that posture beyond comics.',
    rating: '64%',
    ratingLabel: 'rated "tantissimo" (top mark) — the most liked station of the entire programme',
    recall: '1 pupil in 3 independently formulated "l\'IA può sbagliare i disegni" (AI can get the drawings wrong) — "Human-in-the-Loop a 10 anni", one of the most generalisable findings of the pilot.',
    featured: true,
  },
];
---

<Layout title="Primary School" description="Level 1 — The Four Stations, real content and results from the IC Bianca pilot, AY 2025/26.">
  <section class="section">
    <div class="flex items-center gap-3">
      <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-navy-900 text-lg font-bold text-orange-400">1</span>
      <div>
        <p class="eyebrow">Level 1</p>
        <h1 class="text-3xl font-bold text-navy-950 md:text-4xl">Primary School</h1>
      </div>
      <StatusBadge status="live" label="Real content — IC Bianca pilot, AY 2025/26" />
    </div>
    <p class="mt-5 max-w-3xl text-lg text-navy-700">
      A single half-day session, run in parallel across four stations, delivered by
      Liceo Majorana co-educators to classes of pupils aged 8–11. Below is the real
      specification and the real POST-evaluation results from the 19 May 2026 event
      at IC Bianca, Avola.
    </p>
    <div class="mt-6 flex flex-wrap gap-2 text-sm text-navy-600">
      <span class="tag">Half-day, parallel rotation</span>
      <span class="tag">25–35 min / station</span>
      <span class="tag">2 co-educators per station</span>
      <span class="tag">Teacher observation + Diario di Bordo</span>
      <span class="tag">Immersive room re-aggregation</span>
    </div>
  </section>

  <!-- Stations -->
  <section class="section border-t border-navy-100">
    <p class="eyebrow">Specification</p>
    <h2 class="mt-3 text-3xl font-bold text-navy-950">The Four Stations</h2>
    <p class="mt-3 max-w-3xl text-navy-700">
      Stations 1–3 build the human foundations — talent, contribution, success.
      Station 4 introduces generative AI as an object to be inspected through those
      foundations: the pupil checks the AI, not the other way around.
    </p>

    <div class="mt-10 space-y-6">
      {stations.map((s) => (
        <div class:list={['card md:grid md:grid-cols-[1fr_280px] md:gap-8', s.featured && 'border-orange-200']}>
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-navy-900 text-base font-bold text-orange-400">{s.n}</span>
              <div>
                <h3 class="text-xl font-bold text-navy-950">{s.name}</h3>
                <p class="text-sm font-medium text-orange-600">{s.subtitle}</p>
              </div>
            </div>
            <p class="mt-4 text-sm font-semibold text-navy-900">Educational objective</p>
            <p class="mt-1 text-sm text-navy-700">{s.objective}</p>
            <p class="mt-4 text-sm font-semibold text-navy-900">Materials</p>
            <p class="mt-1 text-sm text-navy-700">{s.materials}</p>
            <p class="mt-4 text-sm font-semibold text-navy-900">Facilitation outline</p>
            <ol class="mt-1 list-decimal space-y-1 pl-5 text-sm text-navy-700">
              {s.outline.map((step) => <li>{step}</li>)}
            </ol>
            <p class="mt-4 text-sm font-semibold text-navy-900">Expected behavioural outcomes</p>
            <p class="mt-1 text-sm text-navy-700">{s.outcomes}</p>
          </div>
          <div class="mt-6 md:mt-0">
            <div class="rounded-lg bg-navy-50 p-4 text-center">
              <p class="stat">{s.rating}</p>
              <p class="mt-1 text-xs text-navy-600">{s.ratingLabel}</p>
            </div>
            <div class="mt-4 rounded-lg bg-orange-100 p-4">
              <p class="text-xs font-semibold uppercase tracking-widest text-orange-700">Concept recall — POST, 19 May 2026</p>
              <p class="mt-2 text-sm text-navy-900">{s.recall}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Cross-station design notes -->
  <section class="section border-t border-navy-100">
    <p class="eyebrow">Delivery design</p>
    <h2 class="mt-3 text-3xl font-bold text-navy-950">How a session runs</h2>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <div class="card">
        <p class="font-bold text-navy-900">Rotation</p>
        <p class="mt-2 text-sm text-navy-700">The four stations run in parallel; each class rotates through all four during a single half-day session.</p>
      </div>
      <div class="card">
        <p class="font-bold text-navy-900">Co-educator pairing</p>
        <p class="mt-2 text-sm text-navy-700">Each station is led by two Liceo Majorana students in tandem, to ensure facilitation continuity.</p>
      </div>
      <div class="card">
        <p class="font-bold text-navy-900">Teacher role</p>
        <p class="mt-2 text-sm text-navy-700">The primary teacher observes and takes the <em>Diario di Bordo Docenti</em> notes — a primary qualitative data source.</p>
      </div>
      <div class="card">
        <p class="font-bold text-navy-900">Material persistence</p>
        <p class="mt-2 text-sm text-navy-700">Post-its produced at each station travel back to the immersive room, where they're re-aggregated into the closing visual of the session.</p>
      </div>
    </div>
  </section>

  <!-- Talento -> Valore -> Successo logic -->
  <section class="section border-t border-navy-100">
    <div class="card bg-navy-950 text-navy-50">
      <p class="text-xs font-semibold uppercase tracking-widest text-orange-400">Design intent</p>
      <p class="mt-3 text-lg">
        The pupil must learn to connect AI to the development of their own
        <strong class="text-orange-300">talent</strong>, in order to create
        <strong class="text-orange-300">value</strong>, in order to have a right measure
        of their personal <strong class="text-orange-300">success</strong>.
      </p>
      <p class="mt-3 text-sm text-navy-300">
        Without that anchoring, children risk treating AI as a substitute for cognition
        rather than a complement to it — and the metaphor of <em>palestra</em> (the gym)
        becomes literal: the three concept stations are the human-formation exercises
        that keep the mind trained.
      </p>
    </div>
  </section>

  <div class="section border-t border-navy-100 text-center">
    <a href="/secondary" class="btn-primary">See Level 2 — Secondary School →</a>
  </div>
</Layout>
